# API Configuration
API_PORT=3333
API_HOST=0.0.0.0

# Database
DB_PATH=./db/groot.db

# Authentication
GROOT_DASHBOARD_TOKEN=your-secure-dashboard-token-here

# OpenClaw Gateway Integration (REQUIRED)
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token-here

# Claude API (if using external Claude calls)
CLAUDE_API_KEY=your-claude-api-key-here

# Redis (Optional, for caching)
REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development
